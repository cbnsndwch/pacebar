{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PaceBar",
  "version": "0.9.0",
  "identifier": "dev.cbnsndwch.pacebar",
  "build": {
    "beforeDevCommand": "bun run bundle:plugins && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run bundle:plugins && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PaceBar",
        "width": 400,
        "height": 500,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/bundled_plugins/**/*",
      "icons/tray-icon.png",
      "icons/icon.png"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIwM0FDNEI1NzUxRkY2ODQKUldTRTloOTF0Y1E2SURwRldzbXV5eHRjMmthdjMwdUIzZGlHUjl6VG1wTitYbzJpcC9sTHh0OE8K",
      "endpoints": [
        "https://github.com/cbnsndwch/pacebar/releases/latest/download/latest.json"
      ]
    }
  }
}
